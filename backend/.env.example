# Required: Path to the OneDrive-synced folder where Power Automate saves emails
# Example: C:\Users\broker\OneDrive\TrailerPark
EMAIL_DIR=

# Required: OpenAI API key for LLM classification and extraction
OPENAI_API_KEY=

# Optional: Database URL (default: sqlite:///data/trailerpark.db)
# DATABASE_URL=sqlite:///data/trailerpark.db

# Optional: How often to scan for new emails (minutes, default: 5)
# SCAN_INTERVAL_MINUTES=5

# Optional: Days before auto-archiving listings (default: 20)
# ARCHIVE_DAYS=20

# Optional: Price difference threshold for deal detection in dollars (default: 10000)
# DEAL_THRESHOLD=10000

# Optional: Where to store copied attachment files (default: data/attachments)
# ATTACHMENT_DIR=data/attachments

# Optional: Delete attachment files for archived listings older than this (days, default: 90)
# ATTACHMENT_MAX_AGE_DAYS=90

# Optional: Log file directory (default: data/logs)
# LOG_DIR=data/logs

# Optional: Server port (default: 8000)
# PORT=8000

# Optional: Backup directory (default: data/backups)
# BACKUP_DIR=data/backups

# Optional: Max concurrent OpenAI API calls (default: 5)
# OPENAI_MAX_CONCURRENT=5
